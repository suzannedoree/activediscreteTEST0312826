                <cell></cell>
                <cell></cell>
                <cell></cell>
              </row>
              <row>
                <cell>Bjorn</cell>
                <cell><m>\checkmark</m></cell>
                <cell></cell>
                <cell><m>\checkmark</m></cell>
                <cell><m>\checkmark</m></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
              </row>
              <row bottom="minor">
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
              </row>
              <row>
                <cell>Cassie</cell>
                <cell></cell>
                <cell><m>\checkmark</m></cell>
                <cell></cell>
                <cell></cell>
                <cell><m>\checkmark</m></cell>
                <cell></cell>
                <cell></cell>
              </row>
              <row bottom="minor">
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
                <cell></cell>
              </row>
              <row>
                <cell>Denise</cell>
