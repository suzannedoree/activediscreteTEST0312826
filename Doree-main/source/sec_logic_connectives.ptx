    <subsubsection>
      <title><xref ref="exer_truthtable_demorgan"></xref> Select Answers and Hints</title>
      <p>
        Hint: One way to set up the truth table is shown in <xref ref="table_truthtable_demorgan"></xref>.
        Feel free to copy the table,
        check the third row, and then fill in the remaining entries.
      </p>
      <table xml:id="table_truthtable_demorgan">
        <title>Truth table for the compound statement <m>P \land  (Q \lor R)</m></title>
        <tabular>
          <row>
            <cell><m>P</m></cell>
            <cell><m>Q</m></cell>
            <cell><m>P \lor Q</m></cell>
            <cell><m>\neg(P \lor Q)</m></cell>
            <cell><m>\neg P</m></cell>
            <cell><m>\neg Q</m></cell>
            <cell><m>\neg P \land \neg Q</m></cell>
          </row>
          <row bottom="minor">
            <cell></cell>
            <cell></cell>
            <cell></cell>
            <cell></cell>
            <cell></cell>
            <cell></cell>
            <cell></cell>
          </row>
          <row>
